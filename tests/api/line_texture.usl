kern(1, 1, 1) line_view_cs(
  inputLine: texture1d<float> #texture(0),
  outputLine: image1d<rgba8unorm, write> #texture(1),
  inputLines: texture1d_array<float> #texture(2),
  outputLines: image1d_array<rgba8unorm, write> #texture(3)
) {
  let lineColor = inputLine.read(2u)
  let arrayColor = inputLines.read(uint2(2, 0))
  outputLine.write(lineColor, 1u)
  outputLines.write(arrayColor, uint2(1, 0))
}
