kern(64, 1, 1) subgroup_cs(values: &[uint] #buffer(0) #group(0),
                            shuffled: &mut [uint] #buffer(1) #group(0),
                            relative: &mut [uint] #buffer(2) #group(0),
                            gid: uint #global_id) {
  shuffled[gid as usize] = simd_shuffle_xor(values[gid as usize], 1u)
  relative[gid as usize] = simd_shuffle_and_fill_down(values[gid as usize],
                                                      0u,
                                                      1u)
}
