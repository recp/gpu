vert tri_vs(vertexId: uint #vertex_id) -> float4 {
  if (vertexId == 0) { return float4(0.0, 0.65, 0.0, 1.0) }
  if (vertexId == 1) { return float4(-0.7, -0.65, 0.0, 1.0) }
  return float4(0.7, -0.65, 0.0, 1.0)
}

pub struct FragmentUniforms {
  tint: float4
}

frag tri_fs(uniforms: FragmentUniforms #buffer(0) #group(0)
            #dynamic_offset) -> float4 {
  return uniforms.tint
}
