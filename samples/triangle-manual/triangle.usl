pub struct VSIn {
  position: float2 #attribute(0)
  color: float4 #attribute(1)
}

pub struct VSOut {
  position: float4 #position
  color: float4
}

pub struct FragmentUniforms {
  tint: float4
}

vert tri_vs(v: VSIn #stage_in) -> VSOut {
  var o: VSOut
  o.position = float4(v.position, 0.0, 1.0)
  o.color = v.color
  return o
}

frag tri_fs(i: VSOut #stage_in, uniforms: FragmentUniforms #buffer(0)) -> float4 {
  return i.color * uniforms.tint
}
